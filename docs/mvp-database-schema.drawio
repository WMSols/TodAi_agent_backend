        <mxCell id="r_turn_user_msg" style="endArrow=ERone;endFill=0;startArrow=ERone;startFill=0;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="agent_turns" target="messages">
          <mxGeometry relative="1" as="geometry">
