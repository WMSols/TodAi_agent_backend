        <mxCell id="r_users_cal_l" value="1:N" style="edgeLabel;html=1;align=center;verticalAlign=middle;" vertex="1" connectable="0" parent="r_users_cal">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint x="10" y="-10" as="offset" /></mxGeometry>
        </mxCell>

        <mxCell id="r_users_conv" style="endArrow=ERmany;endFill=0;startArrow=ERone;startFill=0;html=1;rounded=0;" edge="1" parent="1" source="users" target="conversations">
