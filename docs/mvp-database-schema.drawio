        <mxCell id="r_users_mem" style="endArrow=ERmany;endFill=0;startArrow=ERone;startFill=0;html=1;rounded=0;" edge="1" parent="1" source="users" target="agent_memories">
          <mxGeometry relative="1" as="geometry" />
