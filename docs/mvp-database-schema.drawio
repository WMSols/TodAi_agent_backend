        <mxCell id="r_conv_ctx" style="endArrow=ERone;endFill=0;startArrow=ERone;startFill=0;html=1;rounded=0;" edge="1" parent="1" source="conversations" target="conversation_context">
          <mxGeometry relative="1" as="geometry" />
