        <!-- Flutter / Agent boxes -->
        <mxCell id="flutter_box" value="&lt;b&gt;Flutter app reads/writes&lt;/b&gt;&lt;br&gt;users, user_settings&lt;br&gt;calendar_events&lt;br&gt;conversations, messages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="agent_box" value="&lt;b&gt;AI agent loads each turn&lt;/b&gt;&lt;br&gt;recent messages&lt;br&gt;conversation_context.summary&lt;br&gt;agent_memories (top N)&lt;br&gt;calendar_events (date range)&lt;br&gt;user_settings + timezone" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1">
